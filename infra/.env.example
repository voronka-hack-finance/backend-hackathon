DATABASE_URL=postgresql+psycopg://app:app@postgres:5432/family_budget
CORS_ORIGINS=*
GATEWAY_PUBLIC_URL=http://localhost:8081
JWT_SECRET=change-me
JWT_ISSUER=family-budget-backend
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
UPLOADS_BUCKET=uploaded-files
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/%2F
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_ENABLED=true
REDIS_IDEMPOTENCY_TTL_SECONDS=86400

# Docker build: PyPI mirror (override on VPS if needed)
PIP_INDEX_URL=https://mirror.yandex.ru/mirrors/pypi/simple
PIP_TRUSTED_HOST=mirror.yandex.ru

# Firebase (notification-service only). Never commit real keys to git.
# Option A: path to service account JSON (copy from firebase-service-account.json.example)
FIREBASE_ENABLED=true
FIREBASE_CREDENTIALS_PATH=infra/secrets/firebase-service-account.json

# Option B: separate env vars (private key as one line, use \n for line breaks)
# FIREBASE_PROJECT_ID=your-firebase-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY=your-private-key-body-or-full-pem
# FIREBASE_PRIVATE_KEY_ID=optional-key-id

# Option C: full JSON in one line (escaped)
# FIREBASE_CREDENTIALS_JSON=
