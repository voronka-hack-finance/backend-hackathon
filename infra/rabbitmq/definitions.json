{
  "rabbit_version": "3.13.0",
  "vhosts": [
    {
      "name": "/"
    }
  ],
  "users": [
    {
      "name": "guest",
      "password": "guest",
      "tags": "administrator"
    },
    {
      "name": "finance_ai",
      "password": "finance_ai",
      "tags": "management"
    }
  ],
  "permissions": [
    {
      "user": "guest",
      "vhost": "/",
      "configure": ".*",
      "write": ".*",
      "read": ".*"
    },
    {
      "user": "finance_ai",
      "vhost": "/",
      "configure": "^ai\\..*$",
      "write": "^ai\\..*$",
      "read": "^ai\\..*$"
    }
  ]
}
